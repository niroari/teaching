  <Document>
    <name>טקטוניקת הלוחות — מפת עולם</name>
    <description>מפה אינטראקטיבית של לוחות הטקטוניקה, גבולותיהם וכיווני תנועתם.</description>

    <!-- ========================
         PIN STYLE
    ========================= -->
    <Style id="tectonic-pin">
      <IconStyle>
        <color>ff0000ff</color>
        <scale>1.3</scale>
        <Icon>
          <href>http://maps.google.com/mapfiles/kml/shapes/volcano.png</href>
        </Icon>
      </IconStyle>
      <LabelStyle>
        <color>ffffffff</color>
        <scale>1.1</scale>
      </LabelStyle>
      <BalloonStyle>
        <bgColor>ff222222</bgColor>
        <text><![CDATA[
          <font color="#ffffff"><b>$[name]</b></font><br/><br/>
          <font color="#dddddd">$[description]</font>
        ]]></text>
      </BalloonStyle>
    </Style>

