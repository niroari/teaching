rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is a teacher/admin
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == "niroari@gmail.com" || 
         request.auth.token.email == "nirozari@gmail.com");
    }

    match /users/{userId}/words/{wordId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /chat_assignments/{assignmentId} {
      // Students can create assignments for themselves
      allow create: if request.auth != null && 
        request.resource.data.studentId == request.auth.uid;

      // Students can read their own assignments, teachers can read all
      allow read: if request.auth != null && 
        (resource.data.studentId == request.auth.uid || isAdmin());

      // Only teachers can update (grade) assignments
      allow update: if isAdmin();

      // No one can delete submissions
      allow delete: if false;
    }
  }
}
